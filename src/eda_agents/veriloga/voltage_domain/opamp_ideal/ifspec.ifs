NAME_TABLE:

Spice_Model_Name:      ea_opamp_ideal
C_Function_Name:       ucm_ea_opamp_ideal
Description:           "Behavioural single-pole op-amp (gain A0, pole wp) with output clip"


PORT_TABLE:

Port_Name:             inp              inn              out
Description:           "pos input"      "neg input"      "amp out"
Direction:             in               in               out
Default_Type:          v                v                v
Allowed_Types:         [v]              [v]              [v]
Vector:                no               no               no
Vector_Bounds:         -                -                -
Null_Allowed:          no               no               no


PARAMETER_TABLE:

Parameter_Name:        a0               fp_hz            vmax             vmin
Description:           "DC gain (V/V)"  "pole freq (Hz)" "out clip high"  "out clip low"
Data_Type:             real             real             real             real
Default_Value:         1.0e5            1.0e3            1.0              -1.0
Limits:                -                -                -                -
Vector:                no               no               no               no
Vector_Bounds:         -                -                -                -
Null_Allowed:          yes              yes              yes              yes
