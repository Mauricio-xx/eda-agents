# Also match symlinks to a shared .venv-glayout (worktrees).
.venv-glayout
# Autoresearch digital default output dir (when a test / script runs
# with no explicit work_dir). Never committed.
autoresearch_digital/

# LibreLane run artifacts from bench runs. The adapter symlinks its
# run_dir under bench/cache/librelane_runs/, but the actual runs live
# inside bench/designs/<name>/runs/ — never commit either.
bench/designs/**/runs/
bench/cache/

# Bench runs: only the frozen S9 baseline, the S9-gap-closure LLM
# live-run proof, and a curated README are tracked. Local re-runs stay
# gitignored.
bench/results/*
!bench/results/README.md
!bench/results/s9_initial_smoke/
!bench/results/s9_initial_smoke/**
!bench/results/gap_closure_llm_proof/
!bench/results/gap_closure_llm_proof/**
# Wave-3 parallel workers proof (gap #9). Keep summary + report only,
# not the per-task artefact trees — bench/results/**/*.dat re-asserts
# the ngspice-scratch hygiene for this directory below.
!bench/results/gap_closure_parallel/
!bench/results/gap_closure_parallel/summary.json
!bench/results/gap_closure_parallel/report.md
!bench/results/gap_closure_parallel/README.md
# Final bench run for session S9-gap-closure close-out. Same narrow
# rule as the parallel proof: summary + report + README only.
!bench/results/gap_closure_final/
!bench/results/gap_closure_final/summary.json
!bench/results/gap_closure_final/report.md
!bench/results/gap_closure_final/README.md
# S9-residual-closure (gap #6a) cold-cache flakiness probe. Only the
# consolidated README + TSV are tracked; the 9 per-run report dirs
# stay gitignored under the default bench/results/* rule.
!bench/results/sar11_cold_flakiness_probe/
!bench/results/sar11_cold_flakiness_probe/README.md
!bench/results/sar11_cold_flakiness_probe/runs.tsv
# S9-residual-closure (gap #6b) SAR 11-bit architectural ceiling
# characterization. Track README + sweep.tsv + sweep.json; the 12
# per-config run_NN/ scratch dirs stay gitignored.
!bench/results/sar11_ceiling_characterization/
!bench/results/sar11_ceiling_characterization/README.md
!bench/results/sar11_ceiling_characterization/sweep.tsv
!bench/results/sar11_ceiling_characterization/sweep.json
# S9-residual-closure (gap #4) live-mode digital_autoresearch proof.
# Mirrors the gap_closure_llm_proof / gap_closure_final pattern:
# README + summary.json + report.md + program.md + results.tsv only.
!bench/results/gap_closure_digital_autoresearch_live/
!bench/results/gap_closure_digital_autoresearch_live/README.md
!bench/results/gap_closure_digital_autoresearch_live/summary.json
